[Script]
Boke_Quota = type=http-response,pattern=^https://api.myoland.com/quotas/miraa/(transcribe|ai-explain),requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/mottzz87/crules/main/rewrite/boke/boke_response.js

Boke_Trans = type=http-request,pattern=^https://api.myoland.com/transcribes/miraa/runners/runpod\?version=2,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/mottzz87/crules/main/rewrite/boke/boke_request.js

Boke_VIP = type=http-response,pattern=^https://pay.myoland.com/api/customers/entitlements,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/mottzz87/crules/main/rewrite/boke/boke_response.js

[MITM]
hostname = %APPEND% api.myoland.com, pay.myoland.com